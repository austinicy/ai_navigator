# LLM provider — any ONE of the following keys enables the live flow
# (chat, document signal extraction, roadmap generation).
#
# Set LLM_PROVIDER to explicitly choose: anthropic | openai | deepseek
# If LLM_PROVIDER is unset, the app auto-selects by key presence in this order:
#   anthropic → openai → deepseek
#
# Default models (override with LLM_MODEL):
#   anthropic → claude-sonnet-5
#   openai    → gpt-4o
#   deepseek  → deepseek-chat

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# LLM_PROVIDER=
# LLM_MODEL=
