# LLM provider — any ONE of the following keys enables the live flow
# (chat, document signal extraction, roadmap generation).
#
# Set LLM_PROVIDER to explicitly choose: anthropic | openai | deepseek
# If LLM_PROVIDER is unset, the app auto-selects by key presence in this order:
#   anthropic → openai → deepseek
#
# Default models (override with LLM_MODEL):
#   anthropic → claude-sonnet-5
#   openai    → gpt-4o
#   deepseek  → deepseek-chat

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# LLM_PROVIDER=
# LLM_MODEL=

# --- Shared assessment sessions ---
# Set this in Cloud Run to persist shared web and MCP sessions as JSON objects.
# Leave unset locally to use the in-memory development fallback.
# GCS_SESSION_BUCKET=your-private-gcs-bucket

# --- Agora Conversational AI voice mode ---
# App credentials come from Project Management. Customer credentials come
# from Developer Toolkit -> RESTful API. All values are server-only.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
# Public HTTPS origin Agora can call for the shared assessment LLM.
# Production can use the deployed app URL. Local development needs a tunnel
# such as https://your-subdomain.ngrok-free.app (never localhost).
# AGORA_CUSTOM_LLM_BASE_URL=
# APP_BASE_URL=
# Voice mode uses Agora built-in ASR, DeepSeek/OpenAI for the LLM, and the
# OPENAI_API_KEY above for gpt-4o-mini-tts.

# --- MCP server transport (for the remote voice-device server) ---
# stdio = local CLI usage (default); http = remote HTTPS-hostable server.
# MCP_TRANSPORT=http
# MCP_PORT=8080
